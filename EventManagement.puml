@startuml

!theme plain
hide circle
skinparam linetype ortho

entity "User" as user {
  *id : string <<generated>>
  --
  *username : string
  *email : string
  *password : string
  *role : string <<admin | organizer | user>>
  createdAt : date
}

entity "Event" as event {
  *id : string <<generated>>
  --
  *title : string
  description : text
  *date : date
  location : string
  image : string
  *organizerId : string <<FK>>
  *categoryId : string <<FK>>
  createdAt : date
}

entity "Category" as category {
  *id : string <<generated>>
  --
  *name : string
  icon : string
  color : string
}

entity "Booking" as booking {
  *id : string <<generated>>
  --
  *userId : string <<FK>>
  *eventId : string <<FK>>
  *bookingDate : date
  *status : string <<confirmed | cancelled>>
}

user ||..o{ event : "organizes"
user ||..o{ booking : "makes"
event ||..o{ booking : "has"
category ||..o{ event : "classifies"

@enduml
